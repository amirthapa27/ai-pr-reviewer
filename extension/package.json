{
  "name": "pr-review",
  "displayName": "PR Review",
  "description": "AI-powered code review for your changes before you push. Reviews diffs, shows findings in a panel, and can block push on critical issues.",
  "version": "1.0.0",
  "publisher": "pr-review",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Testing",
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pr-review.reviewChanges",
        "title": "Review Changes",
        "icon": "$(shield)"
      },
      {
        "command": "pr-review.installPrePushHook",
        "title": "Install Pre-Push Hook",
        "icon": "$(lock)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "pr-review.reviewChanges",
          "when": "scmRepositoryCount > 0",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "PR Review",
      "properties": {
        "prReview.apiUrl": {
          "type": "string",
          "default": "http://localhost:3333",
          "description": "Base URL of your PR Review API (e.g. http://localhost:3333 or your deployed app)"
        },
        "prReview.agentId": {
          "type": "string",
          "default": "69b0772e683a2db13f977b9c",
          "description": "Lyzr agent ID (only used when API is Lyzr-backed)"
        },
        "prReview.blockPushOnCritical": {
          "type": "boolean",
          "default": true,
          "description": "When pre-push hook is installed, block push if review finds critical issues"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
